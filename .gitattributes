# Exclude platform-specific shells from language stats
android/** linguist-vendored
ios/** linguist-vendored
windows/** linguist-vendored
linux/** linguist-vendored
macos/** linguist-vendored
web/** linguist-vendored

# Hide auto-generated Dart files (e.g., from build_runner or g.dart files)
*.g.dart linguist-generated
*.freezed.dart linguist-generated

# Explicitly ensure your Dart files are the "Detectable" stars
lib/**/*.dart linguist-detectable